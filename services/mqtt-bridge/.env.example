MQTT_USER=bridge_user
MQTT_PASS=your_password
MQTT_TOPIC_TELEMETRY=sortyx/bins/+/telemetry
MQTT_TOPIC_SNAPSHOT=sortyx/bins/+/snapshot

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# TTN Configuration
TTN_APP_ID=your-ttn-application-id
TTN_API_KEY=ttn-account-v2.xxxxx
TTN_BROKER=nam1.cloud.thethings.network
TTN_PORT=8883

PORT=8080
NODE_ENV=production
